{
  "name": "@enk0ded/serve-index",
  "version": "0.1.3",
  "description": "Hono middleware for serving directory indexes and files",
  "keywords": [
    "directory-index",
    "hono",
    "serve-index",
    "static-files"
  ],
  "homepage": "https://github.com/ENK0DED/serve-index#readme",
  "bugs": {
    "url": "https://github.com/ENK0DED/serve-index/issues"
  },
  "license": "MIT",
  "repository": "https://github.com/ENK0DED/serve-index",
  "files": [
    "README.md",
    "LICENSE",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "smoke:node": "node --input-type=module -e \"import('./dist/index.js').then((mod) => { if (typeof mod.serveIndex !== 'function') { throw new TypeError('serveIndex export missing'); } })\"",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "pack:check": "npm pack --dry-run",
    "bench:html": "bun run scripts/bench-html-streaming.ts",
    "prepack": "bun run build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run fmt:check && bun run test && bun run build && bun run smoke:node && bun run pack:check"
  },
  "dependencies": {
    "hono": "^4.12.12",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.12"
}
